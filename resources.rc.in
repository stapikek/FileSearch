#include <winver.h>

1 RT_MANIFEST "@APP_MANIFEST_FILE@"

IDI_ICON1 ICON "@FILESEARCH_ICON_FILE@"

VS_VERSION_INFO VERSIONINFO
FILEVERSION 1,1,0,0
PRODUCTVERSION 1,1,0,0
FILEFLAGSMASK VS_FFI_FILEFLAGSMASK
#ifdef _DEBUG
FILEFLAGS VS_FF_DEBUG
#else
FILEFLAGS 0x0L
#endif
FILEOS VOS__WINDOWS32
FILETYPE VFT_APP
FILESUBTYPE VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "041904b0"
        BEGIN
            VALUE "CompanyName", "stapi"
            VALUE "FileDescription", "FileSearch"
            VALUE "FileVersion", "1.1"
            VALUE "InternalName", "FileSearch"
            VALUE "LegalCopyright", "stapi"
            VALUE "OriginalFilename", "FileSearch.exe"
            VALUE "ProductName", "FileSearch"
            VALUE "ProductVersion", "1.1"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x419, 1200
    END
END